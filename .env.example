# ============================================================
# CONFIGURABLE VALUES - replace with your own
# Copy to .env.local and fill in real values
# ============================================================

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase DB (for migrations + seed scripts)
SUPABASE_DB_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# Auth providers (OAuth)
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Apple: https://developer.apple.com/account/resources/services/
APPLE_CLIENT_ID="your-apple-services-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"

# Email (Resend) - https://resend.com/api-keys
RESEND_API_KEY="re_placeholder"
INQUIRY_TO_EMAIL="owner@example.com"
INQUIRY_FROM_EMAIL="listings@yourdomain.com"

# AI Services (OpenAI) - https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-placeholder"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="AI Real Estate Listings"

# Payments (stubbed for future upgrades)
STRIPE_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
PAYPAL_CLIENT_ID="placeholder"
PAYPAL_CLIENT_SECRET="placeholder"
